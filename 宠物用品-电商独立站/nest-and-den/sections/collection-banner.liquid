<section class="collection-banner">
  {%- if collection.image != blank -%}
    {{ collection.image | image_url: width: 2400 | image_tag:
        widths: '800, 1200, 1800, 2400',
        sizes: '100vw',
        loading: 'eager',
        fetchpriority: 'high',
        alt: collection.title }}
  {%- elsif section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2400 | image_tag:
        widths: '800, 1200, 1800, 2400',
        sizes: '100vw',
        loading: 'eager',
        alt: section.settings.heading }}
  {%- else -%}
    <img src="https://images.unsplash.com/photo-1601758124510-52d02ddb7cbd?auto=format&fit=crop&w=2400&q=80"
         alt="A dog and cat sharing the morning light on a wooden floor"
         loading="eager"
         fetchpriority="high">
  {%- endif -%}

  <div class="collection-banner__copy" data-reveal>
    <div>
      <span class="eyebrow" style="color:var(--linen)">{{ section.settings.eyebrow | default: 'The Daily' }}</span>
      <h1>{{ collection.title | default: section.settings.heading | default: 'For Cats' }}</h1>
      {%- if collection.description != blank or section.settings.body != blank -%}
        <p>{{ collection.description | default: section.settings.body }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Fallback image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Daily" },
    { "type": "text", "id": "heading", "label": "Heading (used if collection has no title)", "default": "For Cats" },
    { "type": "textarea", "id": "body", "label": "Body (used if collection has no description)",
      "default": "Beds, bowls, towers, and toys made of considered materials — for the quietest member of the household." }
  ],
  "presets": [{ "name": "Collection banner" }]
}
{% endschema %}
