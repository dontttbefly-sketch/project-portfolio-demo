<section class="recommendations">
  <div class="recommendations__inner">
    <div class="section-head" data-reveal>
      <div class="section-head__copy">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="recommendations__grid">
      {%- if recommendations.products_count > 0 -%}
        {%- for product in recommendations.products limit: 4 -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- assign demo_titles = 'The Daily Bowl,The Daily Lead,The Daily Coat,The Daily Knot' | split: ',' -%}
        {%- assign demo_prices = '$42,$88,$128,$24' | split: ',' -%}
        {%- assign demo_images = 'https://images.unsplash.com/photo-1602522953585-ba17a47f6cdf?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1601758124510-52d02ddb7cbd?auto=format&fit=crop&w=800&q=80' | split: ',' -%}
        {%- for title in demo_titles -%}
          {%- assign idx = forloop.index0 -%}
          {%- capture fb -%}{ "title": "{{ title }}", "price": "{{ demo_prices[idx] }}", "image": "{{ demo_images[idx] }}", "swatches": ["bone","linen","russet"] }{%- endcapture -%}
          {%- assign fb = fb | parse_json -%}
          {% render 'product-card', fallback: fb %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product recommendations",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pairs well" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pairs well with The Daily Bed." }
  ],
  "presets": [{ "name": "Product recommendations" }]
}
{% endschema %}
