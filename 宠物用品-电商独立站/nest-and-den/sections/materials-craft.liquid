<section class="section section--bone">
  <div class="container">
    <div class="section-head" data-reveal>
      <div class="section-head__copy">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="materials">
      {%- for block in section.blocks -%}
        <div class="material-card" {{ block.shopify_attributes }} data-reveal>
          <div class="material-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                  widths: '400, 800, 1000',
                  sizes: '(min-width: 800px) 33vw, 100vw',
                  loading: 'lazy',
                  alt: block.settings.title }}
            {%- else -%}
              <img src="{{ block.settings.placeholder_url | default: 'https://images.unsplash.com/photo-1604147706283-d7119b5b822c?auto=format&fit=crop&w=800&q=80' }}"
                   alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <span class="eyebrow">{{ block.settings.eyebrow }}</span>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Materials & craft",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Considered Materials" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built to live with you for a long time." }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "placeholder_url", "label": "Placeholder URL (dev only)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "01 / Linen" },
        { "type": "text", "id": "title", "label": "Title", "default": "OEKO-TEX® Linen" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Woven in Lithuania from European flax. Softens with every wash. Naturally hypoallergenic and machine-washable at home." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Materials & craft",
      "blocks": [
        {
          "type": "material",
          "settings": {
            "placeholder_url": "https://images.unsplash.com/photo-1604147706283-d7119b5b822c?auto=format&fit=crop&w=800&q=80",
            "eyebrow": "01 / Linen",
            "title": "OEKO-TEX® Linen",
            "body": "Woven in Lithuania from European flax. Softens with every wash. Naturally hypoallergenic and machine-washable at home."
          }
        },
        {
          "type": "material",
          "settings": {
            "placeholder_url": "https://images.unsplash.com/photo-1610701596061-2ecf227e85b2?auto=format&fit=crop&w=800&q=80",
            "eyebrow": "02 / Ceramic",
            "title": "Food-Grade Ceramic",
            "body": "Wheel-thrown stoneware finished with a lead-free, FDA-approved glaze. Heavier on the floor; gentler on whiskers."
          }
        },
        {
          "type": "material",
          "settings": {
            "placeholder_url": "https://images.unsplash.com/photo-1611371805429-8b5c1b2c34ba?auto=format&fit=crop&w=800&q=80",
            "eyebrow": "03 / Leather",
            "title": "Vegetable-Tanned Leather",
            "body": "Full-grain hides tanned with chestnut bark in Tuscany. No chrome, no shortcuts. Patinas like a pair of well-loved boots."
          }
        }
      ]
    }
  ]
}
{% endschema %}
