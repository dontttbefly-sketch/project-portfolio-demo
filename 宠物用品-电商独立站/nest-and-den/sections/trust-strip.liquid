<section class="trust-strip">
  <div class="trust-strip__grid">
    {%- for block in section.blocks -%}
      <div class="trust-strip__item" {{ block.shopify_attributes }} data-reveal>
        {%- case block.settings.icon -%}
          {%- when 'truck' -%}{% render 'icon-truck' %}
          {%- when 'shield' -%}{% render 'icon-shield' %}
          {%- when 'leaf' -%}{% render 'icon-leaf' %}
          {%- when 'sparkle' -%}{% render 'icon-sparkle' %}
          {%- when 'paw' -%}{% render 'icon-paw' %}
          {%- when 'return' -%}{% render 'icon-return' %}
          {%- else -%}{% render 'icon-paw' %}
        {%- endcase -%}
        <span class="eyebrow">{{ block.settings.title }}</span>
        <p>{{ block.settings.body }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust strip",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "shield", "label": "Shield (vet/safety)" },
            { "value": "leaf", "label": "Leaf (sustainability)" },
            { "value": "sparkle", "label": "Sparkle (heirloom)" },
            { "value": "paw", "label": "Paw (cats & dogs)" },
            { "value": "return", "label": "Return arrow" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Free U.S. Shipping" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "On orders over $75. Ships from Brooklyn within 2 business days." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        {
          "type": "item",
          "settings": { "icon": "truck", "title": "Free U.S. Shipping", "body": "On orders over $75. Ships from Brooklyn in 2 business days." }
        },
        {
          "type": "item",
          "settings": { "icon": "shield", "title": "Vet-Reviewed", "body": "Foods and supplements formulated with practicing veterinarians." }
        },
        {
          "type": "item",
          "settings": { "icon": "sparkle", "title": "Heirloom Materials", "body": "OEKO-TEX® linen, food-grade ceramic, vegetable-tanned leather." }
        },
        {
          "type": "item",
          "settings": { "icon": "return", "title": "60-Day Returns", "body": "Wash it, sleep on it, walk on it. Return it within 60 days." }
        }
      ]
    }
  ]
}
{% endschema %}
