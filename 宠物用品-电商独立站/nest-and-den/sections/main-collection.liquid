{%- paginate collection.products by 12 -%}
<section class="collection-layout">
  <aside class="collection-filters" aria-label="Filter products">
    {%- if collection.filters and collection.filters.size > 0 -%}
      {%- for filter in collection.filters -%}
        <div class="collection-filter">
          <h6>{{ filter.label }}</h6>
          <ul>
            {%- for v in filter.values -%}
              <li>
                <a href="{{ v.url_to_add }}" aria-current="{% if v.active %}true{% else %}false{% endif %}">
                  {{ v.label }} <span>{{ v.count }}</span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="collection-filter">
        <h6>Type</h6>
        <ul>
          <li><a href="?type=Bed">Bed <span>4</span></a></li>
          <li><a href="?type=Bowl">Bowl <span>3</span></a></li>
          <li><a href="?type=Lead">Lead <span>2</span></a></li>
          <li><a href="?type=Coat">Coat <span>2</span></a></li>
          <li><a href="?type=Toy">Toy <span>4</span></a></li>
        </ul>
      </div>
      <div class="collection-filter">
        <h6>Size</h6>
        <ul>
          <li><a href="?size=Small">Small <span>5</span></a></li>
          <li><a href="?size=Medium">Medium <span>7</span></a></li>
          <li><a href="?size=Large">Large <span>4</span></a></li>
        </ul>
      </div>
      <div class="collection-filter">
        <h6>Color</h6>
        <ul>
          <li><a href="?color=Bone">Bone <span>9</span></a></li>
          <li><a href="?color=Linen">Linen <span>7</span></a></li>
          <li><a href="?color=Moss">Moss <span>5</span></a></li>
          <li><a href="?color=Russet">Russet <span>5</span></a></li>
        </ul>
      </div>
      <div class="collection-filter">
        <h6>Price</h6>
        <ul>
          <li><a href="?price=under-50">Under $50 <span>4</span></a></li>
          <li><a href="?price=50-150">$50 — $150 <span>6</span></a></li>
          <li><a href="?price=150-300">$150 — $300 <span>4</span></a></li>
        </ul>
      </div>
    {%- endif -%}
  </aside>

  <div>
    <div class="collection-toolbar">
      <span>{{ collection.products_count | default: 14 }} products</span>
      {%- if collection.sort_options -%}
        <form>
          <select name="sort_by" onchange="this.form.submit()">
            {%- for opt in collection.sort_options -%}
              <option value="{{ opt.value }}" {% if collection.sort_by == opt.value %}selected{% endif %}>{{ opt.name }}</option>
            {%- endfor -%}
          </select>
        </form>
      {%- else -%}
        <span>Sort: Featured</span>
      {%- endif -%}
    </div>

    <div class="collection-grid">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
          {%- if forloop.index == 6 -%}
            <div class="editorial-insert" data-reveal>
              <div>
                <span class="eyebrow">Editor's note</span>
                <h3>The Daily Bowl, in three sizes.</h3>
                <p>Wheel-thrown ceramic, glazed in our four heirloom tones. Heavy on the floor, gentle on whiskers.</p>
                <a class="btn--text" href="/products/the-daily-bowl">Read the story {% render 'icon-arrow-right' %}</a>
              </div>
              <div>
                <img src="https://images.unsplash.com/photo-1602522953585-ba17a47f6cdf?auto=format&fit=crop&w=900&q=80"
                     alt="" loading="lazy"
                     style="width:100%; aspect-ratio:4/3; object-fit:cover">
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign demo_titles = 'The Daily Bed,The Daily Bowl,The Daily Lead,The Daily Coat,The Daily Tower,The Daily Knot,The Daily Mouse,The Daily Kibble,The Daily Collar' | split: ',' -%}
        {%- assign demo_prices = '$148,$42,$88,$128,$245,$24,$28,$58/mo,$68' | split: ',' -%}
        {%- assign demo_images = 'https://images.unsplash.com/photo-1583511655826-05700d52f4d9?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1602522953585-ba17a47f6cdf?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1574144611937-0df059b5ef3e?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1601758124510-52d02ddb7cbd?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1606214174585-fe31582dc6ee?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1568640347023-a616a30bc3bd?auto=format&fit=crop&w=800&q=80,https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?auto=format&fit=crop&w=800&q=80' | split: ',' -%}
        {%- for title in demo_titles -%}
          {%- assign idx = forloop.index0 -%}
          {%- capture fb -%}{ "title": "{{ title }}", "price": "{{ demo_prices[idx] }}", "image": "{{ demo_images[idx] }}", "swatches": ["bone","linen","moss","russet"] }{%- endcapture -%}
          {%- assign fb = fb | parse_json -%}
          {% render 'product-card', fallback: fb %}
          {%- if forloop.index == 6 -%}
            <div class="editorial-insert" data-reveal>
              <div>
                <span class="eyebrow">Editor's note</span>
                <h3>The Daily Bowl, in three sizes.</h3>
                <p>Wheel-thrown ceramic, glazed in our four heirloom tones. Heavy on the floor, gentle on whiskers.</p>
                <a class="btn--text" href="/products/the-daily-bowl">Read the story {% render 'icon-arrow-right' %}</a>
              </div>
              <div>
                <img src="https://images.unsplash.com/photo-1602522953585-ba17a47f6cdf?auto=format&fit=crop&w=900&q=80"
                     alt="" loading="lazy" style="width:100%; aspect-ratio:4/3; object-fit:cover">
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">{% render 'icon-arrow-right' %}</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span aria-current="true">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{% render 'icon-arrow-right' %}</a>{%- endif -%}
      </nav>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection grid",
  "settings": []
}
{% endschema %}
