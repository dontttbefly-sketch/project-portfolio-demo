<section class="section section--cream">
  <div class="container">
    <div class="essay" data-reveal>
      <div class="essay__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag:
              widths: '500, 800, 1200',
              sizes: '(min-width: 900px) 50vw, 100vw',
              loading: 'lazy',
              alt: section.settings.image.alt | default: section.settings.heading }}
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1518791841217-8f162f1e1131?auto=format&fit=crop&w=1200&q=80"
               alt="A senior cat resting on a stack of folded linens"
               loading="lazy">
        {%- endif -%}
      </div>
      <div class="essay__copy">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <div>{{ section.settings.body }}</div>
        {%- if section.settings.signature != blank -%}
          <p class="signature">{{ section.settings.signature }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand essay",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Approach" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We design for the way pets actually live." },
    { "type": "richtext", "id": "body", "label": "Body",
      "default": "<p>Most pet goods are made for stores, not homes — bright, branded, and stacked on a shelf. We start the other way around: from a kitchen counter, a worn-in armchair, the linen sheet your dog has chosen as his own.</p><p>Every piece in The Daily is meant to be left out. To be folded into the rhythm of a household, not stowed in a closet between visits.</p>" },
    { "type": "text", "id": "signature", "label": "Signature", "default": "— The studio, Brooklyn" }
  ],
  "presets": [{ "name": "Brand essay" }]
}
{% endschema %}
